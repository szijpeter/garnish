{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "gradle",
    "gradle-wrapper",
    "github-actions"
  ],
  "labels": [
    "dependencies"
  ],
  "schedule": [
    "before 5am on monday"
  ],
  "timezone": "Etc/UTC",
  "prConcurrentLimit": 8,
  "prHourlyLimit": 2,
  "ignoreUnstable": true,
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true
}
